{
  "//": "Template showing EVERY configuration key. Copy to appsettings.json / appsettings.{Environment}.json or supply via environment variables / a secret manager. Replace every <PLACEHOLDER>. Secrets MUST come from a secret store, never source control.",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=<HOST>;Port=5432;Database=<DB>;Username=<USER>;Password=<PLACEHOLDER>"
  },
  "Database": {
    "MigrateOnStartup": false,
    "SeedOnStartup": false
  },
  "Jwt": {
    "Issuer": "<ISSUER_URL>",
    "Audience": "<AUDIENCE>",
    "SigningKey": "<PLACEHOLDER_HS256_KEY_MIN_32_BYTES>",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Encryption": {
    "Key": "<PLACEHOLDER_BASE64_32_BYTE_AES_KEY>"
  },
  "Otp": {
    "Length": 6,
    "TtlMinutes": 5,
    "MaxAttempts": 5,
    "RequestsPerHour": 5,
    "DevFixedCode": ""
  },
  "//Otp.DevFixedCode": "DEV/TEST ONLY: a fixed OTP (e.g. '333333') that skips the SMS gateway. MUST be empty in production.",
  "InvestmentReservation": {
    "WindowDays": 3,
    "SweepIntervalMinutes": 15,
    "SweepBatchSize": 100
  },
  "//InvestmentReservation": "How long an offering application holds its reserved tokens before a background sweep returns them to the pool, and how that sweep is paced. Optional; these defaults apply when the section is absent.",
  "Didit": {
    "ApiKey": "<PLACEHOLDER>",
    "WebhookSecret": "<PLACEHOLDER>",
    "BaseUrl": "https://verification.didit.me",
    "WorkflowId": "6531ead8-b352-4345-9ff8-5488b8be83ed",
    "WebhookToleranceSeconds": 300
  },
  "NikitaPro": {
    "Login": "<LOGIN>",
    "Sender": "<SENDER_NAME>",
    "ApiKey": "<PLACEHOLDER>",
    "BaseUrl": "https://smspro.nikita.kg/api/"
  },
  "S3": {
    "BucketName": "<BUCKET>",
    "Region": "<AWS_REGION>",
    "ServiceUrl": null
  },
  "Tessera": {
    "PolicyId": "<POLICY_ID>",
    "IssuerDid": "<ISSUER_DID>"
  },
  "Blockchain": {
    "SignerUrl": "<EXTERNAL_SIGNER_URL>",
    "ChainId": "<EVM_CHAIN_ID>",
    "TokenContractAddress": "<TOKEN_CONTRACT_ADDRESS>",
    "AnchorNetwork": "<ANCHOR_NETWORK>"
  }
}

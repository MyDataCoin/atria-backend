# Template for the gitignored `.env` placed next to docker-compose.yml on the server
# (and used for local `docker compose up`). Copy to `.env` and fill in real values.
#
# These are SHELL variables that docker-compose interpolates into the api service's
# `environment:` block (e.g. ${NIKITA_PRO_LOGIN} -> NikitaPro__Login, ${DIDIT_API_KEY} ->
# Didit__ApiKey). Each one is guarded with `:?` in docker-compose.yml, so if any is unset
# or empty the stack REFUSES to boot with a clear error — the app can never run with blank
# credentials. On deploy these same variables come from GitHub Actions secrets (see
# .github/workflows/deploy.yml); this file is only for local runs.
#
# Values are taken LITERALLY: no surrounding quotes, no trailing spaces, no CRLF.

# Nikita Pro SMS gateway (smspro.nikita.kg) — OTP delivery.
NIKITA_PRO_LOGIN=CHANGE_ME
NIKITA_PRO_API_KEY=CHANGE_ME

# Postgres password for the local stack. Must match the existing atria-pgdata volume.
POSTGRES_PASSWORD=CHANGE_ME

# Didit hosted-KYC secrets. WorkflowId is NOT here — it's non-secret config in appsettings.json.
DIDIT_API_KEY=CHANGE_ME
DIDIT_WEBHOOK_SECRET=CHANGE_ME

# Admin / Realtor / SuperAdmin logins are DB-only — no config here. Each is an ordinary users row
# (username + password hash). Create them with scripts/seed-superadmin.sql, then log in via
# POST /auth/admin/login (admin & super-admin) or /auth/realtor/login with username + password.

# Base URL for realtor referral links (the referral token is appended as ?ref=...). Points at the
# investor frontend's invest landing, e.g. https://atria.app/invest. Optional.
REFERRAL_BASE_URL=

# Template for the gitignored `.env` placed next to docker-compose.yml on the server
# (and used for local `docker compose up`). Copy to `.env` and fill in real values.
#
# Keys use the ASP.NET double-underscore convention: A__B maps to config "A:B".
# If `.env` is absent the app falls back to appsettings.json defaults so the stack still boots.

# Nikita Pro SMS gateway (smspro.nikita.kg) — OTP delivery secrets.
NikitaPro__Login=CHANGE_ME
NikitaPro__ApiKey=CHANGE_ME